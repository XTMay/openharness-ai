{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XTMay/openharness-ai/docs/schemas/repository-manifest.schema.json",
  "title": "OpenHarness Repository Manifest",
  "type": "object",
  "required": [
    "repository",
    "generated_at",
    "total_files",
    "total_bytes",
    "languages",
    "package_managers",
    "frameworks",
    "service_entrypoints",
    "api_routes",
    "performance_targets",
    "infrastructure",
    "test_inventory",
    "warnings"
  ],
  "properties": {
    "repository": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": { "type": "string" },
        "current_branch": { "type": ["string", "null"] },
        "commit_sha": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "total_files": { "type": "integer", "minimum": 0 },
    "total_bytes": { "type": "integer", "minimum": 0 },
    "languages": {
      "type": "array",
      "items": { "$ref": "#/$defs/language" }
    },
    "package_managers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "frameworks": {
      "type": "array",
      "items": { "$ref": "#/$defs/framework" }
    },
    "service_entrypoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/service_entrypoint" }
    },
    "api_routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/api_route" }
    },
    "performance_targets": {
      "type": "array",
      "items": { "$ref": "#/$defs/performance_target" }
    },
    "infrastructure": {
      "type": "array",
      "items": { "type": "string" }
    },
    "test_inventory": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "evidence": {
      "type": "object",
      "required": ["source", "detail"],
      "properties": {
        "source": { "type": "string" },
        "detail": { "type": "string" },
        "line": { "type": ["integer", "null"], "minimum": 1 }
      },
      "additionalProperties": false
    },
    "language": {
      "type": "object",
      "required": ["name", "files", "bytes"],
      "properties": {
        "name": { "type": "string" },
        "files": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "framework": {
      "type": "object",
      "required": ["name", "confidence", "evidence"],
      "properties": {
        "name": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    },
    "service_entrypoint": {
      "type": "object",
      "required": ["kind", "path", "confidence", "evidence"],
      "properties": {
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "command": { "type": ["string", "null"] },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    },
    "api_route": {
      "type": "object",
      "required": ["method", "path", "source", "framework", "confidence", "evidence"],
      "properties": {
        "method": { "type": "string" },
        "path": { "type": "string" },
        "source": { "type": "string" },
        "framework": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    },
    "performance_target": {
      "type": "object",
      "required": ["method", "path", "source", "framework", "priority", "reason", "evidence"],
      "properties": {
        "method": { "type": "string" },
        "path": { "type": "string" },
        "source": { "type": "string" },
        "framework": { "type": "string" },
        "priority": { "$ref": "#/$defs/priority" },
        "reason": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    }
  }
}

